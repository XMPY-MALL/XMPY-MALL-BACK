<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xmpy.demo.mapper.ReviewMapper">

    <resultMap id="UserResult" type="com.xmpy.demo.entity.User">
        <id     property="userId"   column="user_id"/>
        <result property="userName" column="user_name"/>
    </resultMap>

    <resultMap id="ReviewWithUser" type="com.xmpy.demo.entity.Review">
        <id     property="reviewId"    column="review_id"/>
        <result property="productId"   column="product_id"/>
        <result property="orderItemId" column="order_item_id"/>
        <result property="content"     column="content"/>
        <result property="createdAt"   column="created_at"/>
        <association property="user" resultMap="UserResult"/>
    </resultMap>

    <select id="findByProductId" resultMap="ReviewWithUser">
        SELECT
            r.review_id,
            r.product_id,
            r.order_item_id,
            r.content,
            r.created_at,
            u.user_id,
            u.user_name
        FROM
            review_tb r
        JOIN
            user_tb u ON r.user_id = u.user_id
        WHERE
            r.product_id = #{productId}
        ORDER BY
            r.created_at DESC
        LIMIT
            #{limit}
        OFFSET
            #{offset}
    </select>

    <select id="countByProductId" resultType="long">
        SELECT
            COUNT(*)
        FROM
            review_tb
        WHERE
            product_id = #{productId}
    </select>

</mapper>